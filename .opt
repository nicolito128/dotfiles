#!/usr/bin/env bash

export ODIN_USER_PATH="$HOME/opt/odin"
export FLUTTER_SDK_PATH="$HOME/opt/flutter/bin"

dirs=(
    "$ODIN_USER_PATH"
    "$FLUTTER_SDK_PATH"
)

# Add to PATH
for dir in "${dirs[@]}"; do
    if [[ -d "$dir" ]] && [[ ":$PATH:" != *":$dir:"* ]]; then
        export PATH="$PATH:$dir"
    fi
done

